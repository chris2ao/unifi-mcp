# UniFi MCP environment variables.
# Copy this file to a sourced location (e.g. ~/.claude/secrets/secrets.env
# which is sourced from ~/.zshrc) and fill in the values.
#
# DO NOT commit your filled-in copy.

# Required. Full URL to your UniFi console's local IP.
# Use the LAN IP, not unifi.ui.com. Cloud keys do not authenticate against
# /proxy/network/* or /proxy/protect/integration/v1/*.
UNIFI_HOST=https://192.168.1.1

# Required. Local-console API key from:
#   Console device pill > Settings > Control Plane > Integrations > Create API Key
UNIFI_API_KEY=paste-your-key-here

# Optional. The site short-name (internalReference). Defaults to "default".
# UNIFI_SITE=default

# Optional. Set to "true" if your console presents a valid SSL certificate.
# Defaults to "false" to tolerate the self-signed cert UniFi ships with.
# UNIFI_VERIFY_SSL=false
